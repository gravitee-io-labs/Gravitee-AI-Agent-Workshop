  "plans": [
    {
      "definitionVersion": "V4",
      "flows": [
        {
          "name": "Agent Card",
          "enabled": true,
          "selectors": [
            {
              "type": "HTTP",
              "path": "/.well-known/agent-card.json",
              "pathOperator": "EQUALS",
              "methods": [
                "GET"
              ]
            }
          ],
          "request": [
            {
              "name": "Rate Limit",
              "description": "Protect from Resource Exhaustion",
              "enabled": true,
              "policy": "rate-limit",
              "configuration": {
                "async": false,
                "addHeaders": false,
                "rate": {
                  "useKeyOnly": false,
                  "periodTime": 1,
                  "limit": 10,
                  "periodTimeUnit": "SECONDS",
                  "key": ""
                },
                "errorStrategy": "FALLBACK_PASS_TROUGH"
              }
            }
          ],
          "response": [],
          "subscribe": [],
          "publish": [],
          "entrypointConnect": [],
          "interact": [],
          "tags": []
        },
        {
          "name": "Message sent to Agent",
          "enabled": true,
          "selectors": [
            {
              "type": "HTTP",
              "path": "/",
              "pathOperator": "EQUALS",
              "methods": [
                "POST"
              ]
            },
            {
              "type": "CONDITION",
              "condition": "{#jsonPath(#request.content, '$.method') == 'message/send'}"
            }
          ],
          "request": [
            {
              "name": "Rate Limit",
              "description": "Protect from Resource Exhaustion",
              "enabled": true,
              "policy": "rate-limit",
              "configuration": {
                "async": false,
                "addHeaders": false,
                "rate": {
                  "useKeyOnly": false,
                  "periodTime": 1,
                  "limit": 5,
                  "periodTimeUnit": "SECONDS",
                  "key": ""
                },
                "errorStrategy": "FALLBACK_PASS_TROUGH"
              }
            }
          ],
          "response": [],
          "subscribe": [],
          "publish": [],
          "entrypointConnect": [],
          "interact": [],
          "tags": []
        }
      ],
