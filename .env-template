# Gravitee License (base64 encoded)
GRAVITEE_LICENSE=PUT_YOUR_BASE64_LICENSE_HERE

# Gravitee API Management
APIM_REGISTRY=graviteeio
# https://hub.docker.com/r/graviteeio/apim-gateway/tags?name=4.11
APIM_VERSION=4.11.0-alpha.2
APIM_VERSION_GATEWAY=4.11.0-alpha.2-debian #Debian version is needed to run the local AI models used for the Guard Rails policy

# Gravitee Access Management
AM_REGISTRY=graviteeio
# https://hub.docker.com/r/graviteeio/am-gateway/tags?name=4.11
AM_VERSION=4.11.0-alpha.3

# Gravitee Alerting Engine
# https://hub.docker.com/r/graviteeio/ae-engine/tags?name=2
AE_VERSION=2.3.2

# Databases versions
# https://hub.docker.com/_/mongo/tags?name=8.0
MONGODB_VERSION=8.0.20
# https://www.docker.elastic.co/r/elasticsearch/elasticsearch
ELASTIC_VERSION=9.3.2

# AI
# https://hub.docker.com/r/ollama/ollama/tags
OLLAMA_VERSION=0.19.0
MCP_INSPECTOR_VERSION=latest